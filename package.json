{
  "name": "aventuras",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "Aventuras — cross-platform app (Expo on mobile, Electron on desktop).",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:docs": "remark . --quiet --frail",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:start": "electron electron/dist/main.js",
    "desktop": "concurrently -k -n expo,electron -c blue,magenta \"cross-env BROWSER=none expo start --web --port 8081\" \"wait-on http://localhost:8081 && pnpm electron:compile && pnpm electron:start\"",
    "build:web": "expo export --platform web",
    "build:desktop": "pnpm build:web && pnpm electron:compile && electron-builder",
    "build:desktop:linux": "pnpm build:web && pnpm electron:compile && electron-builder --linux",
    "build:desktop:mac": "pnpm build:web && pnpm electron:compile && electron-builder --mac",
    "build:desktop:win": "pnpm build:web && pnpm electron:compile && electron-builder --win",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "build-storybook": "storybook build",
    "themes:audit": "tsx scripts/themes-audit.ts",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:check:format": "tsx scripts/check-migrations-format.ts",
    "db:seed": "tsx scripts/seed/index.ts",
    "db:studio:desktop": "drizzle-kit studio --config drizzle.studio.config.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai-compatible": "^2.0.49",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.1.33",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.24",
    "ai": "^6.0.193",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "expo": "~55.0.17",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "i18next": "^26.3.0",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-haptic-feedback": "^3.0.0",
    "react-native-keyboard-controller": "1.21.8",
    "react-native-reanimated": "~4.2.1",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sortables": "^1.9.4",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "reanimated-color-picker": "^4.2.0",
    "sqlite-vec": "^0.1.9",
    "tailwind-merge": "^3.5.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-native-web-vite": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "babel-plugin-inline-import": "^3.0.0",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-storybook": "10.3.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "expo-drizzle-studio-plugin": "^0.2.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "only-allow": "^1.2.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint-no-duplicate-headings": "^4.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-validate-links": "^13.1.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.aventuras.app",
    "productName": "Aventuras",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "electron/dist/**/*",
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sqlite-vec-*/**"
    ],
    "extraResources": [
      {
        "from": "lib/db/migrations",
        "to": "migrations"
      }
    ],
    "extraMetadata": {
      "main": "electron/dist/main.js"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  },
  "private": true,
  "remarkConfig": {
    "plugins": [
      "remark-frontmatter",
      [
        "remark-validate-links",
        {
          "repository": false
        }
      ],
      "remark-preset-lint-recommended",
      "remark-lint-no-duplicate-headings"
    ]
  },
  "author": {
    "name": "Failerko",
    "email": "20503476+failerko@users.noreply.github.com",
    "url": "https://github.com/AventurasTeam"
  },
  "homepage": "https://github.com/AventurasTeam",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
